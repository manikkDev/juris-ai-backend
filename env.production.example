# Production Environment Variables for Backend (Cloud Functions)
# Copy this to .env in Cloud Functions environment config

# Firebase is auto-configured in Cloud Functions
# No need to set FIREBASE_* variables

# JWT Secret (IMPORTANT: Use a strong secret in production)
JWT_SECRET=your-production-jwt-secret-here

# CORS Origins (Add your Firebase Hosting URL)
ALLOWED_ORIGINS=https://your-project-id.web.app,https://your-project-id.firebaseapp.com

# ML Service URL (Cloud Run URL after deployment)
ML_SERVICE_URL=https://juris-ai-ml-xxxxxxxxxx-uc.a.run.app
